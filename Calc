<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ChronoCalc Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --primary: #4f46e5; }
        .bg-glass { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); }
        .dark .bg-glass { background: rgba(17, 24, 39, 0.95); }
        .stat-card { transition: all 0.3s ease; }
    </style>
</head>
<body class="bg-slate-50 dark:bg-slate-900 transition-colors duration-300 min-h-screen font-sans text-slate-900 dark:text-slate-100">

    <nav class="sticky top-0 z-50 bg-glass border-b border-slate-200 dark:border-slate-800 p-4">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <h1 class="text-xl font-bold flex items-center gap-2">
                <i class="fas fa-hourglass-half text-indigo-600"></i> ChronoCalc
            </h1>
            <button id="themeToggle" class="p-2 rounded-full hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
                <i class="fas fa-moon dark:hidden"></i>
                <i class="fas fa-sun hidden dark:block"></i>
            </button>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto p-4 md:p-8">
        <div class="grid md:grid-cols-2 gap-6 mb-8">
            <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700">
                <label class="block text-sm font-semibold text-slate-500 mb-2 uppercase tracking-wider">Date de Début</label>
                <input type="date" id="dob" class="w-full bg-slate-50 dark:bg-slate-900 border-none p-3 rounded-xl focus:ring-2 focus:ring-indigo-500 font-medium text-lg text-slate-900 dark:text-white">
                <p id="dayDob" class="mt-2 text-sm text-indigo-600 font-medium"></p>
            </div>
            <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700">
                <label class="block text-sm font-semibold text-slate-500 mb-2 uppercase tracking-wider">Date de Fin</label>
                <input type="date" id="currentDate" class="w-full bg-slate-50 dark:bg-slate-900 border-none p-3 rounded-xl focus:ring-2 focus:ring-indigo-500 font-medium text-lg text-slate-900 dark:text-white">
                <p id="dayCurrent" class="mt-2 text-sm text-slate-500 font-medium"></p>
            </div>
        </div>

        <div class="grid grid-cols-3 gap-4 mb-8">
            <div class="stat-card bg-indigo-600 text-white p-4 rounded-2xl text-center shadow-lg">
                <span class="block text-xs opacity-80 uppercase font-bold mb-1">Années</span>
                <span id="resYear" class="text-3xl font-black">0</span>
            </div>
            <div class="stat-card bg-white dark:bg-slate-800 p-4 rounded-2xl text-center shadow-sm border border-slate-100 dark:border-slate-700">
                <span class="block text-xs text-slate-500 uppercase font-bold mb-1">Mois</span>
                <span id="resMonth" class="text-3xl font-black text-indigo-600 dark:text-indigo-400">0</span>
            </div>
            <div class="stat-card bg-white dark:bg-slate-800 p-4 rounded-2xl text-center shadow-sm border border-slate-100 dark:border-slate-700">
                <span class="block text-xs text-slate-500 uppercase font-bold mb-1">Jours</span>
                <span id="resDay" class="text-3xl font-black text-indigo-600 dark:text-indigo-400">0</span>
            </div>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-3xl p-6 shadow-sm border border-slate-100 dark:border-slate-700 mb-8">
            <h2 class="text-lg font-bold mb-6 flex items-center gap-2">
                <i class="fas fa-chart-line text-indigo-500"></i> Équivalences Totales
            </h2>
            <div class="space-y-6">
                <div>
                    <div class="flex justify-between mb-2">
                        <span class="text-sm font-medium text-slate-500">Total en Mois</span>
                        <span id="totalMonths" class="font-bold text-indigo-600">0</span>
                    </div>
                    <div class="w-full bg-slate-100 dark:bg-slate-700 h-2 rounded-full overflow-hidden">
                        <div id="barMonths" class="bg-indigo-500 h-full transition-all duration-700" style="width: 0%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between mb-2">
                        <span class="text-sm font-medium text-slate-500">Total en Jours</span>
                        <span id="totalDays" class="font-bold text-emerald-600">0</span>
                    </div>
                    <div class="w-full bg-slate-100 dark:bg-slate-700 h-2 rounded-full overflow-hidden">
                        <div id="barDays" class="bg-emerald-500 h-full transition-all duration-700" style="width: 0%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex flex-wrap gap-4">
            <button onclick="copyResults()" class="flex-1 bg-slate-900 dark:bg-indigo-600 text-white font-bold py-4 px-6 rounded-2xl flex items-center justify-center gap-2 active:scale-95 transition-transform">
                <i class="fas fa-copy"></i> Copier
            </button>
            <button onclick="resetDates()" class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 py-4 px-8 rounded-2xl active:scale-95 transition-transform">
                <i class="fas fa-undo"></i>
            </button>
        </div>

        <div id="toast" class="fixed bottom-8 left-1/2 -translate-x-1/2 bg-slate-900 text-white px-6 py-3 rounded-full text-sm opacity-0 transition-opacity pointer-events-none">
            Copié !
        </div>
    </main>

    <script>
        const dobInput = document.getElementById('dob');
        const currentInput = document.getElementById('currentDate');
        const daysFr = ['Dimanche', 'Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi'];

        // Thème
        if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        }

        // Valeurs par défaut (Aujourd'hui et 2017)
        dobInput.value = "2017-08-06";
        currentInput.value = new Date().toISOString().split('T')[0];

        function updateCalculations() {
            const d1 = new Date(dobInput.value);
            const d2 = new Date(currentInput.value);

            if (isNaN(d1.getTime()) || isNaN(d2.getTime())) return;

            // Affichage des noms de jours
            document.getElementById('dayDob').textContent = daysFr[d1.getDay()];
            document.getElementById('dayCurrent').textContent = daysFr[d2.getDay()];

            // Logique de calcul précise
            let start = d1 < d2 ? d1 : d2;
            let end = d1 < d2 ? d2 : d1;

            let years = end.getFullYear() - start.getFullYear();
            let months = end.getMonth() - start.getMonth();
            let days = end.getDate() - start.getDate();

            if (days < 0) {
                months--;
                let prevMonth = new Date(end.getFullYear(), end.getMonth(), 0);
                days += prevMonth.getDate();
            }
            if (months < 0) {
                years--;
                months += 12;
            }

            // Totaux
            const diffMs = Math.abs(d2 - d1);
            const totalDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
            const totalMonths = (years * 12) + months;

            // Update UI
            document.getElementById('resYear').textContent = years;
            document.getElementById('resMonth').textContent = months;
            document.getElementById('resDay').textContent = days;
            document.getElementById('totalMonths').textContent = totalMonths.toLocaleString();
            document.getElementById('totalDays').textContent = totalDays.toLocaleString();

            // Barres de progression dynamiques
            document.getElementById('barMonths').style.width = Math.min((totalMonths / 120) * 100, 100) + '%';
            document.getElementById('barDays').style.width = Math.min((totalDays / 3650) * 100, 100) + '%';
        }

        function resetDates() {
            currentInput.value = new Date().toISOString().split('T')[0];
            updateCalculations();
        }

        async function copyResults() {
            const text = `Durée : ${document.getElementById('resYear').textContent} ans, ${document.getElementById('resMonth').textContent} mois, ${document.getElementById('resDay').textContent} jours.`;
            await navigator.clipboard.writeText(text);
            const t = document.getElementById('toast');
            t.style.opacity = '1';
            setTimeout(() => t.style.opacity = '0', 2000);
        }

        document.getElementById('themeToggle').addEventListener('click', () => {
            document.documentElement.classList.toggle('dark');
            localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
        });

        // Écouteurs pour le calcul automatique immédiat
        [dobInput, currentInput].forEach(input => {
            input.addEventListener('input', updateCalculations);
            input.addEventListener('change', updateCalculations);
            input.addEventListener('blur', updateCalculations);
        });

        // Lancer au démarrage
        updateCalculations();
    </script>
</body>
</html>
