<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ChronoCalc Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .stat-card { transition: transform 0.2s; }
        .stat-card:active { transform: scale(0.95); }
        input[type="date"] { -webkit-appearance: none; min-height: 2.5rem; }
    </style>
</head>
<body class="bg-slate-50 dark:bg-slate-950 min-h-screen font-sans text-slate-900 dark:text-slate-100 transition-colors">

    <nav class="bg-emerald-600 dark:bg-emerald-800 text-white p-4 shadow-md">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <h1 class="text-xl font-bold flex items-center gap-2">
                <i class="fas fa-calendar-check"></i> ChronoCalc Pro
            </h1>
            <button id="themeToggle" class="p-2 bg-emerald-500 rounded-lg">
                <i class="fas fa-moon"></i>
            </button>
        </div>
    </nav>

    <main class="max-w-xl mx-auto p-6">
        
        <div class="space-y-4 mb-8">
            <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl shadow-sm border-2 border-emerald-100 dark:border-slate-800">
                <label class="block text-xs font-black text-emerald-600 uppercase mb-1">Date de début</label>
                <input type="date" id="dob" class="w-full bg-transparent text-lg outline-none font-bold">
            </div>

            <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl shadow-sm border-2 border-emerald-100 dark:border-slate-800">
                <label class="block text-xs font-black text-emerald-600 uppercase mb-1">Date de fin</label>
                <input type="date" id="currentDate" class="w-full bg-transparent text-lg outline-none font-bold">
            </div>

            <button onclick="calculate()" class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-black py-5 rounded-2xl shadow-lg shadow-emerald-200 dark:shadow-none text-xl transition-all">
                <i class="fas fa-play-circle mr-2"></i> CALCULER
            </button>
        </div>

        <div class="grid grid-cols-3 gap-3 mb-6">
            <div class="bg-slate-800 text-white p-4 rounded-2xl text-center">
                <span class="block text-[10px] uppercase opacity-60">Années</span>
                <span id="resYear" class="text-3xl font-black">0</span>
            </div>
            <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl text-center border border-slate-200 dark:border-slate-800">
                <span class="block text-[10px] uppercase text-slate-400">Mois</span>
                <span id="resMonth" class="text-3xl font-black text-emerald-500">0</span>
            </div>
            <div class="bg-white dark:bg-slate-900 p-4 rounded-2xl text-center border border-slate-200 dark:border-slate-800">
                <span class="block text-[10px] uppercase text-slate-400">Jours</span>
                <span id="resDay" class="text-3xl font-black text-emerald-500">0</span>
            </div>
        </div>

        <div class="bg-emerald-50 dark:bg-slate-900/50 p-5 rounded-3xl border border-emerald-100 dark:border-slate-800">
            <div class="flex justify-between mb-4">
                <span class="text-sm font-bold text-slate-500">Total en mois</span>
                <span id="totalMonths" class="font-black text-emerald-700 dark:text-emerald-400">0</span>
            </div>
            <div class="flex justify-between">
                <span class="text-sm font-bold text-slate-500">Total en jours</span>
                <span id="totalDays" class="font-black text-emerald-700 dark:text-emerald-400">0</span>
            </div>
        </div>

        <div class="mt-8 flex gap-3">
            <button onclick="copyResults()" class="flex-1 bg-slate-200 dark:bg-slate-800 font-bold py-3 rounded-xl text-sm uppercase tracking-widest">
                <i class="fas fa-copy mr-2"></i> Copier
            </button>
            <button onclick="window.location.reload()" class="bg-slate-200 dark:bg-slate-800 px-6 py-3 rounded-xl">
                <i class="fas fa-sync-alt"></i>
            </button>
        </div>

    </main>

    <script>
        // Initialisation des dates
        document.getElementById('dob').value = "2017-08-06";
        document.getElementById('currentDate').value = new Date().toISOString().split('T')[0];

        function calculate() {
            const v1 = document.getElementById('dob').value;
            const v2 = document.getElementById('currentDate').value;

            if (!v1 || !v2) return;

            let d1 = new Date(v1);
            let d2 = new Date(v2);

            // Gestion de l'ordre des dates
            let start = d1 < d2 ? d1 : d2;
            let end = d1 < d2 ? d2 : d1;

            let years = end.getFullYear() - start.getFullYear();
            let months = end.getMonth() - start.getMonth();
            let days = end.getDate() - start.getDate();

            if (days < 0) {
                months--;
                let lastDay = new Date(end.getFullYear(), end.getMonth(), 0).getDate();
                days += lastDay;
            }
            if (months < 0) {
                years--;
                months += 12;
            }

            const totalDaysCount = Math.floor(Math.abs(d2 - d1) / (1000 * 60 * 60 * 24));

            // Mise à jour de l'affichage
            document.getElementById('resYear').innerText = years;
            document.getElementById('resMonth').innerText = months;
            document.getElementById('resDay').innerText = days;
            document.getElementById('totalMonths').innerText = (years * 12 + months).toLocaleString();
            document.getElementById('totalDays').innerText = totalDaysCount.toLocaleString();
        }

        async function copyResults() {
            const y = document.getElementById('resYear').innerText;
            const m = document.getElementById('resMonth').innerText;
            const d = document.getElementById('resDay').innerText;
            await navigator.clipboard.writeText(`Durée : ${y} ans, ${m} mois, ${d} jours.`);
            alert("Copié !");
        }

        // Mode sombre
        document.getElementById('themeToggle').addEventListener('click', () => {
            document.documentElement.classList.toggle('dark');
        });

        // Lancer un premier calcul
        calculate();
    </script>
</body>
</html>
