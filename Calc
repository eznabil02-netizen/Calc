<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ChronoCalc Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .stat-card { transition: all 0.3s ease; }
        input[type="date"] { -webkit-appearance: none; min-height: 1.5em; }
    </style>
</head>
<body class="bg-slate-50 dark:bg-slate-900 transition-colors duration-300 min-h-screen font-sans text-slate-900 dark:text-slate-100">

    <nav class="sticky top-0 z-50 bg-white/95 dark:bg-slate-900/95 backdrop-blur border-b border-slate-200 dark:border-slate-800 p-4">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <h1 class="text-xl font-bold flex items-center gap-2">
                <i class="fas fa-hourglass-half text-indigo-600"></i> ChronoCalc
            </h1>
            <button id="themeToggle" class="p-2 rounded-full hover:bg-slate-200 dark:hover:bg-slate-700">
                <i class="fas fa-moon dark:hidden"></i>
                <i class="fas fa-sun hidden dark:block"></i>
            </button>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto p-4 md:p-8">
        <div class="grid md:grid-cols-2 gap-6 mb-8">
            <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700">
                <label class="block text-sm font-bold text-slate-500 mb-2 uppercase">Date de Début</label>
                <input type="date" id="dob" class="w-full bg-slate-100 dark:bg-slate-900 p-3 rounded-xl focus:ring-2 focus:ring-indigo-500 text-lg dark:text-white">
            </div>
            <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700">
                <label class="block text-sm font-bold text-slate-500 mb-2 uppercase">Date de Fin</label>
                <input type="date" id="currentDate" class="w-full bg-slate-100 dark:bg-slate-900 p-3 rounded-xl focus:ring-2 focus:ring-indigo-500 text-lg dark:text-white">
            </div>
        </div>

        <div class="grid grid-cols-3 gap-4 mb-8">
            <div class="stat-card bg-indigo-600 text-white p-4 rounded-2xl text-center shadow-lg">
                <span class="block text-xs opacity-80 uppercase font-bold">Années</span>
                <span id="resYear" class="text-3xl font-black">0</span>
            </div>
            <div class="stat-card bg-white dark:bg-slate-800 p-4 rounded-2xl text-center border border-slate-100 dark:border-slate-700">
                <span class="block text-xs text-slate-500 uppercase font-bold">Mois</span>
                <span id="resMonth" class="text-3xl font-black text-indigo-600 dark:text-indigo-400">0</span>
            </div>
            <div class="stat-card bg-white dark:bg-slate-800 p-4 rounded-2xl text-center border border-slate-100 dark:border-slate-700">
                <span class="block text-xs text-slate-500 uppercase font-bold">Jours</span>
                <span id="resDay" class="text-3xl font-black text-indigo-600 dark:text-indigo-400">0</span>
            </div>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-3xl p-6 shadow-sm border border-slate-100 dark:border-slate-700 mb-8">
            <div class="space-y-4">
                <div class="flex justify-between"><span class="text-slate-500">Total en Mois</span><span id="totalMonths" class="font-bold text-indigo-600">0</span></div>
                <div class="flex justify-between"><span class="text-slate-500">Total en Jours</span><span id="totalDays" class="font-bold text-emerald-600">0</span></div>
            </div>
        </div>

        <button onclick="copyResults()" class="w-full bg-slate-900 dark:bg-indigo-600 text-white font-bold py-4 rounded-2xl active:scale-95 transition-transform">
            <i class="fas fa-copy mr-2"></i> Copier le résumé
        </button>
        <div id="toast" class="fixed bottom-8 left-1/2 -translate-x-1/2 bg-black text-white px-6 py-3 rounded-full text-sm opacity-0 transition-opacity">Copié !</div>
    </main>

    <script>
        const dobInput = document.getElementById('dob');
        const currentInput = document.getElementById('currentDate');

        // Thème
        if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        }
        document.getElementById('themeToggle').addEventListener('click', () => {
            document.documentElement.classList.toggle('dark');
            localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
        });

        // Initialisation
        dobInput.value = "2017-08-06";
        currentInput.value = new Date().toISOString().split('T')[0];

        function calculate() {
            // On récupère la valeur brute de l'input
            const v1 = dobInput.value;
            const v2 = currentInput.value;
            
            if(!v1 || !v2) return;

            // Création des dates en forçant le format UTC pour éviter les décalages de fuseau horaire
            const d1 = new Date(v1);
            const d2 = new Date(v2);

            if (isNaN(d1.getTime()) || isNaN(d2.getTime())) return;

            let start = d1 < d2 ? d1 : d2;
            let end = d1 < d2 ? d2 : d1;

            let years = end.getFullYear() - start.getFullYear();
            let months = end.getMonth() - start.getMonth();
            let days = end.getDate() - start.getDate();

            if (days < 0) {
                months--;
                let lastDayPrevMonth = new Date(end.getFullYear(), end.getMonth(), 0).getDate();
                days += lastDayPrevMonth;
            }
            if (months < 0) {
                years--;
                months += 12;
            }

            const totalDays = Math.floor(Math.abs(d2 - d1) / (1000 * 60 * 60 * 24));

            // Affichage direct
            document.getElementById('resYear').innerText = years;
            document.getElementById('resMonth').innerText = months;
            document.getElementById('resDay').innerText = days;
            document.getElementById('totalMonths').innerText = (years * 12 + months).toLocaleString();
            document.getElementById('totalDays').innerText = totalDays.toLocaleString();
        }

        // Écouteurs ultra-sensibles
        [dobInput, currentInput].forEach(el => {
            el.addEventListener('input', calculate);
            el.addEventListener('change', calculate);
            el.addEventListener('blur', calculate);
        });

        async function copyResults() {
            const text = `Durée : ${document.getElementById('resYear').innerText} ans, ${document.getElementById('resMonth').innerText} mois, ${document.getElementById('resDay').innerText} jours.`;
            await navigator.clipboard.writeText(text);
            const t = document.getElementById('toast');
            t.style.opacity = '1';
            setTimeout(() => t.style.opacity = '0', 2000);
        }

        // Lancement immédiat
        calculate();
    </script>
</body>
</html>
